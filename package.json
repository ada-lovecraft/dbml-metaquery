{
  "name": "dbml-metaquery",
  "version": "1.2.0",
  "description": "Parse DBML into a navigable graph with rich metadata -- FK path finding, table info, groups, and schema search.",
  "type": "module",
  "bin": {
    "dbml-metaquery": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/cli.ts src/tools.ts --outdir dist --target node --format esm --sourcemap=linked && bun build src/index.ts src/cli.ts src/tools.ts --outdir dist --target bun --format esm --entry-naming '[dir]/[name].bun.[ext]' && printf '#!/usr/bin/env node\\n' | cat - dist/cli.js > dist/cli.tmp && mv dist/cli.tmp dist/cli.js && bunx tsc --project tsconfig.build.json",
    "cli": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "bun": "./dist/index.bun.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "bun": "./dist/cli.bun.js",
      "import": "./dist/cli.js"
    },
    "./tools": {
      "bun": "./dist/tools.bun.js",
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "dependencies": {
    "@dbml/parse": "^7.0.0-alpha.0",
    "graphology": "^0.25.4",
    "graphology-shortest-path": "^2.1.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "@types/bun": "latest",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "keywords": [
    "dbml",
    "database",
    "schema",
    "graph",
    "path-finding",
    "metadata"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ada-lovecraft/dbml-metaquery.git"
  },
  "license": "MIT"
}
